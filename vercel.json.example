{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "",
  "outputDirectory": "frontend",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE-WITH-YOUR-RENDER-APP.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://REPLACE-WITH-YOUR-RENDER-APP.onrender.com/ws/:path*"
    }
  ]
}
